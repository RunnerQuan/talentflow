classDiagram
    direction TB

    %% ───────── Database Layer ─────────
    class TalentFlowDB {
        -db: IDBPDatabase~unknown~
        +open(): Promise~void~
        +getAllCandidates(): Promise~Candidate[]~
        +getCandidate(id: string): Promise~Candidate | undefined~
        +putCandidate(candidate: Candidate): Promise~void~
        +deleteCandidate(id: string): Promise~void~
        +getMatchByCandidate(candidateId: string): Promise~MatchResult | undefined~
        +putMatch(match: MatchResult): Promise~void~
        +getResumeFile(candidateId: string): Promise~ResumeFileMeta | undefined~
        +putResumeFile(candidateId: string, blob: Blob): Promise~void~
        +deleteResumeFile(candidateId: string): Promise~void~
    }

    %% ───────── Core Domain Models ─────────
    class Candidate {
        +id: string
        +profile: CandidateProfile
        +resumeFile: ResumeFileMeta | null
        +tags: string[]
        +status: CandidateStatus
        +createdAt: string
        +updatedAt: string
    }

    class CandidateProfile {
        +name: string
        +email: string
        +phone: string
        +summary: string
        +education: Education[]
        +workExperience: WorkExperience[]
        +projects: Project[]
        +skills: Skill[]
        +yearsOfExperience: number
        +currentTitle: string
        +currentCompany: string
        +rawText?: string
    }

    class ResumeFileMeta {
        +name: string
        +type: string
        +size: number
    }

    %% ───────── Existing Types (extended) ─────────
    class MatchResult {
        +candidateId: string
        +overallScore: number
        +dimensions: MatchDimension[]
        +strengths: string[]
        +weaknesses: string[]
        +recommendation: string
        +candidateName: string
        +createdAt: string
    }

    class MatchDimension {
        +name: string
        +score: number
        +weight: number
        +details: string[]
    }

    class Education {
        +school: string
        +degree: string
        +major: string
        +startDate: string
        +endDate: string
        +gpa?: string
    }

    class WorkExperience {
        +company: string
        +title: string
        +startDate: string
        +endDate: string
        +description: string
    }

    class Project {
        +name: string
        +role: string
        +startDate: string
        +endDate: string
        +description: string
        +technologies: string[]
    }

    class Skill {
        +name: string
        +level: number
        +category: string
    }

    class InterviewRecord {
        +id: string
        +candidateId: string
        +round: InterviewRound
        +questions: InterviewQuestion[]
        +evaluations: InterviewEvaluation[]
        +overallScore: number
        +recommendation: string
        +summary: string
        +createdAt: string
    }

    class InterviewQuestion {
        +id: string
        +question: string
        +category: string
        +difficulty: string
        +expectedAnswer?: string
        +followUp?: string
    }

    class InterviewEvaluation {
        +questionId: string
        +answer: string
        +score: number
        +feedback: string
    }

    %% ───────── Zustand Stores ─────────
    class ResumeStore {
        +candidates: Candidate[]
        +activeCandidateIndex: number
        +isUploading: boolean
        +error: string | null
        +loadFromDB(): Promise~void~
        +addCandidate(candidate: Candidate): Promise~void~
        +removeCandidate(index: number): Promise~void~
        +setActiveCandidate(index: number): void
        +clearAll(): Promise~void~
    }

    class MatchStore {
        +results: MatchResult[]
        +activeResultIndex: number
        +jdText: string
        +isMatching: boolean
        +error: string | null
        +loadFromDB(): Promise~void~
        +addResult(result: MatchResult): Promise~void~
        +setActiveResult(index: number): void
        +clearResults(): Promise~void~
    }

    class ModelStore {
        +settings: ModelSettings
        +visionSettings: VisionModelSettings
        +loadFromStorage(): void
    }

    %% ───────── Relationships ─────────
    Candidate *-- CandidateProfile : profile
    Candidate *-- ResumeFileMeta : resumeFile
    ResumeStore --> TalentFlowDB : reads/writes
    MatchStore --> TalentFlowDB : reads/writes
    MatchResult --> MatchDimension : dimensions
    InterviewRecord --> InterviewQuestion : questions
    InterviewRecord --> InterviewEvaluation : evaluations
    InterviewRecord ..> Candidate : candidateId
    MatchResult ..> Candidate : candidateId
    CandidateProfile *-- Education
    CandidateProfile *-- WorkExperience
    CandidateProfile *-- Project
    CandidateProfile *-- Skill
