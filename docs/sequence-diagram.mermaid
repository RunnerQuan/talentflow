sequenceDiagram
    title 应用启动 — 数据加载
    autonumber

    participant Layout as app/layout.tsx<br/>(ClientLayout)
    participant MS as model-store
    participant RS as resume-store
    participant MTS as match-store
    participant DB as lib/db.ts
    participant IDB as IndexedDB

    Layout->>MS: loadFromStorage() [已有逻辑, localStorage]
    MS-->>Layout: modelSettings loaded

    Layout->>RS: loadFromDB()
    RS->>DB: getAllCandidates()
    DB->>IDB: transaction('candidates').getAll()
    IDB-->>DB: Candidate[]
    DB-->>RS: Candidate[]
    Note over RS: set({ candidates })

    Layout->>MTS: loadFromDB()
    MTS->>DB: getAllMatches()
    DB->>IDB: transaction('matches').getAll()
    IDB-->>DB: MatchResult[]
    DB-->>MTS: MatchResult[]
    Note over MTS: set({ results })

---

sequenceDiagram
    title 简历解析 → 存储候选人
    autonumber

    participant User as 用户
    participant Upload as upload/page.tsx
    participant API as api/parse-resume/route.ts
    participant RS as resume-store
    participant DB as lib/db.ts
    participant IDB as IndexedDB
    participant Router as next/router

    User->>Upload: 选择文件 (PDF/图片, ≤10MB)
    User->>Upload: 点击「AI 解析简历」
    Upload->>Upload: 校验文件大小

    Upload->>API: POST /api/parse-resume (FormData)
    Note over API: modelSettings + visionSettings
    API-->>Upload: { candidate: CandidateProfile }

    Upload->>Upload: 构建 Candidate 对象<br/>id = crypto.randomUUID()
    Upload->>RS: addCandidate(candidate)
    RS->>DB: putCandidate(candidate)
    DB->>IDB: transaction('candidates').put(candidate)
    RS->>DB: putResumeFile(candidateId, fileBlob)
    DB->>IDB: transaction('files').put({candidateId, blob})

    Upload->>Router: router.push('/candidates')

---

sequenceDiagram
    title 候选人列表 → 详情 → 侧边抽屉
    autonumber

    participant User as 用户
    participant List as candidates/page.tsx
    participant Card as candidate-card.tsx
    participant Detail as candidates/[id]/page.tsx
    participant Tabs as candidate-detail-tabs.tsx
    participant Drawer as resume-drawer.tsx
    participant DB as lib/db.ts
    participant IDB as IndexedDB

    User->>List: 访问 /candidates
    List->>List: 从 resume-store 读 candidates[]

    alt 卡片视图
        List->>Card: 渲染 CandidateCard[]
    else 表格视图
        List->>List: 渲染 CandidateTable
    end

    User->>Card: 点击候选人卡片
    Card->>Router: router.push('/candidates/[id]')

    Detail->>DB: getCandidate(id)
    DB->>IDB: transaction('candidates').get(id)
    IDB-->>DB: Candidate
    DB-->>Detail: Candidate

    Detail->>Tabs: 渲染 4 Tab 容器
    Tabs->>Tabs: Tab 1: Overview (默认)
    Note over Tabs: 复用 skill-graph.tsx<br/>for Tab 2

    User->>Tabs: 点击「查看原始简历」按钮
    Tabs->>Drawer: openDrawer(candidateId)
    Drawer->>DB: getResumeFile(candidateId)
    DB->>IDB: transaction('files').get(candidateId)
    IDB-->>DB: { blob: Blob, ... }
    DB-->>Drawer: Blob

    alt PDF 文件
        Drawer->>Drawer: react-pdf Document/Page 渲染
    else 图片文件
        Drawer->>Drawer: <img src={URL.createObjectURL(blob)} />
    end

---

sequenceDiagram
    title 匹配结果保存与查看
    autonumber

    participant Match as match/page.tsx
    participant MS as match-store
    participant DB as lib/db.ts
    participant IDB as IndexedDB
    participant Detail as candidates/[id] tab-match

    Match->>Match: AI 匹配计算
    Match->>MS: addResult(matchResult)
    Note over MS: 构建 MatchResult<br/>candidateId = activeCandidate.id
    MS->>DB: putMatch(matchResult)
    DB->>IDB: transaction('matches').put(matchResult)

    Note over Detail: 候选人详情页 Tab 4
    Detail->>DB: getMatchByCandidate(candidateId)
    DB->>IDB: transaction('matches').get(candidateId)
    IDB-->>DB: MatchResult
    DB-->>Detail: MatchResult
    Detail->>Detail: 渲染匹配结果卡片
